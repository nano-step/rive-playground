{
  "name": "rive-playground",
  "version": "1.0.0",
  "description": "Inspect, control & export Rive .riv animations — CLI, MCP server, and visual playground",
  "type": "module",
  "main": "dist/mcp.js",
  "bin": {
    "rive-analyzer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev:mcp": "tsx src/mcp.ts",
    "dev:cli": "tsx src/cli.ts",
    "start:mcp": "node dist/mcp.js",
    "start:cli": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@rive-app/canvas-advanced": "^2.36.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "glob": "^10.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
